# Mock .env for the walkthrough fetcher repo.
# Some keys are intentionally left unset so the Secrets screen
# shows both 'set' and 'missing' states.

OKTA_API_TOKEN=mock-okta-token-abc123
# OKTA_ORG_URL intentionally not set — shows as 'missing' in Secrets

ACME_API_KEY=mock-acme-secret-xyz789
ACME_REGION=us-east-1

# GITHUB_TOKEN intentionally not set — shows as 'missing' in Secrets
GITHUB_ORG=paramify
